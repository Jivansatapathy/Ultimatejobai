rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isEmployer() {
      return signedIn() && userProfile().data.role in ['employer', 'admin'];
    }

    match /users/{userId} {
      allow read, create, update: if signedIn() && request.auth.uid == userId;
    }

    match /jobs/{jobId} {
      allow read, write: if isEmployer() && resource.data.employerId == request.auth.uid;
      allow create: if isEmployer() && request.resource.data.employerId == request.auth.uid;
    }

    match /applications/{applicationId} {
      allow read, write: if isEmployer() && resource.data.employerId == request.auth.uid;
      allow create: if isEmployer() && request.resource.data.employerId == request.auth.uid;
    }

    match /activity/{activityId} {
      allow read, write: if isEmployer() && resource.data.employerId == request.auth.uid;
      allow create: if isEmployer() && request.resource.data.employerId == request.auth.uid;
    }
  }
}
