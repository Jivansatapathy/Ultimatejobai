{
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://jobai-production-83b7.up.railway.app/api/$1"
    },
    {
      "src": "/did/(.*)",
      "dest": "https://jobai-production-83b7.up.railway.app/did/$1"
    },
    {
      "src": "/assets/(.*)",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" },
      "dest": "/assets/$1"
    },
    { "handle": "filesystem" },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
